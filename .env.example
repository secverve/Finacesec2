POSTGRES_DB=fds_platform
POSTGRES_USER=fds_user
POSTGRES_PASSWORD=fds_password
DATABASE_URL=postgresql+psycopg://fds_user:fds_password@postgres:5432/fds_platform
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=change-this-in-production-with-at-least-32-bytes
ACCESS_TOKEN_EXPIRE_MINUTES=480
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
ADMIN_EMAIL=admin@verve.local
ADMIN_PASSWORD=Admin1234!
DEMO_USER_EMAIL=trader@verve.local
DEMO_USER_PASSWORD=Trader1234!
SECOND_USER_EMAIL=analyst@verve.local
SECOND_USER_PASSWORD=Analyst1234!
AUTO_SEED=true
HIGH_AMOUNT_THRESHOLD=1000000
ABNORMAL_REGION_CODES=CN,RU,KP
MULTI_ACCOUNT_WINDOW_MINUTES=10
LOGIN_FAILURE_WINDOW_MINUTES=30
ORDER_SPIKE_MULTIPLIER=3.0
ORDER_CANCEL_BURST_THRESHOLD=3
ORDER_CANCEL_WINDOW_MINUTES=15
IMMEDIATE_ORDER_WINDOW_MINUTES=10
FRONTEND_API_BASE_URL=http://localhost:8000/api/v1
